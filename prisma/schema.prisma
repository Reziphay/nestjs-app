generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum AppRole {
  UCR
  USO
  ADMIN
}

enum OtpPurpose {
  REGISTER
  LOGIN
  VERIFY_PHONE
  CHANGE_PHONE
}

enum MagicLinkPurpose {
  VERIFY_EMAIL
  LOGIN_EMAIL
}

enum BrandStatus {
  ACTIVE
  FLAGGED
  CLOSED
}

enum BrandMembershipRole {
  OWNER
  MEMBER
}

enum BrandMembershipStatus {
  ACTIVE
  REMOVED
}

enum BrandJoinRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum ServiceType {
  SOLO
  MULTI
}

enum ApprovalMode {
  MANUAL
  AUTO
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED_BY_CUSTOMER
  CANCELLED_BY_OWNER
  CHANGE_REQUESTED_BY_CUSTOMER
  CHANGE_REQUESTED_BY_OWNER
  COMPLETED
  NO_SHOW
  EXPIRED
}

enum ReservationActorType {
  SYSTEM
  CUSTOMER
  OWNER
  ADMIN
}

enum ReservationChangeRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum ReservationCompletionMethod {
  QR
  MANUAL
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  fullName        String     @map("full_name")
  email           String?    @unique
  phone           String     @unique
  emailVerifiedAt DateTime?  @map("email_verified_at")
  phoneVerifiedAt DateTime?  @map("phone_verified_at")
  status          UserStatus @default(ACTIVE)
  suspendedUntil  DateTime?  @map("suspended_until")
  closedReason    String?    @map("closed_reason")
  lastLoginAt     DateTime?  @map("last_login_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  roles                          UserRole[]
  authSessions                   AuthSession[]
  emailMagicLinks                EmailMagicLink[]
  ownedBrands                    Brand[]                       @relation("BrandOwner")
  brandMemberships               BrandMembership[]
  brandJoinRequests              BrandJoinRequest[]            @relation("BrandJoinRequestRequester")
  reviewedBrandJoinRequests      BrandJoinRequest[]            @relation("BrandJoinRequestReviewer")
  serviceAddresses               ServiceAddress[]              @relation("ServiceAddressOwner")
  services                       Service[]                     @relation("ServiceOwner")
  customerReservations           Reservation[]                 @relation("ReservationCustomer")
  serviceOwnerReservations       Reservation[]                 @relation("ReservationServiceOwner")
  reservationStatusHistory       ReservationStatusHistory[]    @relation("ReservationStatusActor")
  requestedReservationChanges    ReservationChangeRequest[]    @relation("ReservationChangeRequestedBy")
  reviewedReservationChanges     ReservationChangeRequest[]    @relation("ReservationChangeReviewedBy")
  reservationCompletionActions   ReservationCompletionRecord[] @relation("ReservationCompletionActor")
  verifiedReservationCompletions ReservationCompletionRecord[] @relation("ReservationCompletionVerifiedCustomer")
  uploadedFiles                  FileObject[]                  @relation("UploadedByUser")

  @@index([status], map: "users_status_idx")
  @@map("users")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      AppRole
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role], map: "user_roles_user_id_role_key")
  @@index([role], map: "user_roles_role_idx")
  @@map("user_roles")
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  deviceInfo       String?   @map("device_info")
  ip               String?
  activeRole       AppRole   @default(UCR) @map("active_role")
  lastUsedAt       DateTime? @map("last_used_at")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt], map: "auth_sessions_user_revoked_idx")
  @@index([expiresAt], map: "auth_sessions_expires_at_idx")
  @@map("auth_sessions")
}

model OtpCode {
  id           String     @id @default(uuid()) @db.Uuid
  phone        String
  codeHash     String     @map("code_hash")
  purpose      OtpPurpose
  fullName     String?    @map("full_name")
  email        String?
  expiresAt    DateTime   @map("expires_at")
  consumedAt   DateTime?  @map("consumed_at")
  attemptCount Int        @default(0) @map("attempt_count")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([phone, purpose, consumedAt], map: "otp_codes_phone_purpose_consumed_idx")
  @@index([phone, purpose, expiresAt], map: "otp_codes_phone_purpose_expires_idx")
  @@map("otp_codes")
}

model EmailMagicLink {
  id         String           @id @default(uuid()) @db.Uuid
  userId     String?          @map("user_id") @db.Uuid
  email      String
  tokenHash  String           @map("token_hash")
  purpose    MagicLinkPurpose
  expiresAt  DateTime         @map("expires_at")
  consumedAt DateTime?        @map("consumed_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, purpose, consumedAt], map: "email_magic_links_user_purpose_consumed_idx")
  @@index([email, purpose, expiresAt], map: "email_magic_links_email_purpose_expires_idx")
  @@map("email_magic_links")
}

model Brand {
  id          String      @id @default(uuid()) @db.Uuid
  ownerUserId String      @map("owner_user_id") @db.Uuid
  logoFileId  String?     @map("logo_file_id") @db.Uuid
  name        String
  description String?
  status      BrandStatus @default(ACTIVE)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  owner            User               @relation("BrandOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  logoFile         FileObject?        @relation("BrandLogoFile", fields: [logoFileId], references: [id], onDelete: SetNull)
  memberships      BrandMembership[]
  joinRequests     BrandJoinRequest[]
  addresses        BrandAddress[]
  serviceAddresses ServiceAddress[]
  services         Service[]
  reservations     Reservation[]

  @@index([ownerUserId], map: "brands_owner_user_id_idx")
  @@index([status], map: "brands_status_idx")
  @@map("brands")
}

model BrandAddress {
  id          String   @id @default(uuid()) @db.Uuid
  brandId     String   @map("brand_id") @db.Uuid
  label       String?
  fullAddress String   @map("full_address")
  country     String
  city        String
  lat         Float?
  lng         Float?
  placeId     String?  @map("place_id")
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId, isPrimary], map: "brand_addresses_brand_id_is_primary_idx")
  @@map("brand_addresses")
}

model BrandMembership {
  id             String                @id @default(uuid()) @db.Uuid
  brandId        String                @map("brand_id") @db.Uuid
  userId         String                @map("user_id") @db.Uuid
  membershipRole BrandMembershipRole   @default(MEMBER) @map("membership_role")
  status         BrandMembershipStatus @default(ACTIVE)
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([brandId, userId], map: "brand_memberships_brand_id_user_id_key")
  @@index([userId, status], map: "brand_memberships_user_id_status_idx")
  @@index([brandId, status], map: "brand_memberships_brand_id_status_idx")
  @@map("brand_memberships")
}

model BrandJoinRequest {
  id               String                 @id @default(uuid()) @db.Uuid
  brandId          String                 @map("brand_id") @db.Uuid
  requesterUserId  String                 @map("requester_user_id") @db.Uuid
  message          String?
  status           BrandJoinRequestStatus @default(PENDING)
  reviewedByUserId String?                @map("reviewed_by_user_id") @db.Uuid
  reviewedAt       DateTime?              @map("reviewed_at")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  brand          Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  requesterUser  User  @relation("BrandJoinRequestRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  reviewedByUser User? @relation("BrandJoinRequestReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([brandId, status], map: "brand_join_requests_brand_id_status_idx")
  @@index([requesterUserId, status], map: "brand_join_requests_requester_user_id_status_idx")
  @@map("brand_join_requests")
}

model ServiceCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  parentId  String?  @map("parent_id") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   ServiceCategory?  @relation("ServiceCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children ServiceCategory[] @relation("ServiceCategoryHierarchy")
  services Service[]

  @@index([isActive], map: "service_categories_is_active_idx")
  @@index([parentId], map: "service_categories_parent_id_idx")
  @@map("service_categories")
}

model ServiceAddress {
  id          String   @id @default(uuid()) @db.Uuid
  brandId     String?  @map("brand_id") @db.Uuid
  ownerUserId String?  @map("owner_user_id") @db.Uuid
  label       String?
  fullAddress String   @map("full_address")
  country     String
  city        String
  lat         Float?
  lng         Float?
  placeId     String?  @map("place_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  brand     Brand?    @relation(fields: [brandId], references: [id], onDelete: SetNull)
  ownerUser User?     @relation("ServiceAddressOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  services  Service[]

  @@index([brandId], map: "service_addresses_brand_id_idx")
  @@index([ownerUserId], map: "service_addresses_owner_user_id_idx")
  @@map("service_addresses")
}

model Service {
  id                              String       @id @default(uuid()) @db.Uuid
  ownerUserId                     String       @map("owner_user_id") @db.Uuid
  brandId                         String?      @map("brand_id") @db.Uuid
  categoryId                      String?      @map("category_id") @db.Uuid
  addressId                       String?      @map("address_id") @db.Uuid
  name                            String
  description                     String?
  priceAmount                     Decimal?     @map("price_amount") @db.Decimal(12, 2)
  priceCurrency                   String?      @map("price_currency") @db.VarChar(3)
  waitingTimeMinutes              Int          @map("waiting_time_minutes")
  minAdvanceMinutes               Int?         @map("min_advance_minutes")
  maxAdvanceMinutes               Int?         @map("max_advance_minutes")
  serviceType                     ServiceType  @map("service_type")
  approvalMode                    ApprovalMode @map("approval_mode")
  freeCancellationDeadlineMinutes Int?         @map("free_cancellation_deadline_minutes")
  isActive                        Boolean      @default(true) @map("is_active")
  createdAt                       DateTime     @default(now()) @map("created_at")
  updatedAt                       DateTime     @updatedAt @map("updated_at")

  ownerUser              User                           @relation("ServiceOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  brand                  Brand?                         @relation(fields: [brandId], references: [id], onDelete: SetNull)
  category               ServiceCategory?               @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  address                ServiceAddress?                @relation(fields: [addressId], references: [id], onDelete: SetNull)
  photos                 ServicePhoto[]
  availabilityRules      ServiceAvailabilityRule[]
  availabilityExceptions ServiceAvailabilityException[]
  reservations           Reservation[]

  @@index([ownerUserId, isActive], map: "services_owner_user_id_is_active_idx")
  @@index([brandId], map: "services_brand_id_idx")
  @@index([categoryId], map: "services_category_id_idx")
  @@index([addressId], map: "services_address_id_idx")
  @@index([name], map: "services_name_idx")
  @@map("services")
}

model FileObject {
  id               String   @id @default(uuid()) @db.Uuid
  bucket           String
  objectKey        String   @unique @map("object_key")
  originalFilename String?  @map("original_filename")
  mimeType         String   @map("mime_type")
  sizeBytes        Int      @map("size_bytes")
  uploadedByUserId String?  @map("uploaded_by_user_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  uploadedByUser User?          @relation("UploadedByUser", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  brandsAsLogo   Brand[]        @relation("BrandLogoFile")
  servicePhotos  ServicePhoto[]

  @@index([uploadedByUserId], map: "files_uploaded_by_user_id_idx")
  @@map("files")
}

model ServicePhoto {
  id        String   @id @default(uuid()) @db.Uuid
  serviceId String   @map("service_id") @db.Uuid
  fileId    String   @map("file_id") @db.Uuid
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  service Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  file    FileObject @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([serviceId, fileId], map: "service_photos_service_id_file_id_key")
  @@index([serviceId, sortOrder], map: "service_photos_service_id_sort_order_idx")
  @@map("service_photos")
}

model ServiceAvailabilityRule {
  id        String    @id @default(uuid()) @db.Uuid
  serviceId String    @map("service_id") @db.Uuid
  dayOfWeek DayOfWeek @map("day_of_week")
  startTime String    @map("start_time") @db.VarChar(5)
  endTime   String    @map("end_time") @db.VarChar(5)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, dayOfWeek], map: "service_availability_rules_service_id_day_of_week_idx")
  @@map("service_availability_rules")
}

model ServiceAvailabilityException {
  id             String   @id @default(uuid()) @db.Uuid
  serviceId      String   @map("service_id") @db.Uuid
  date           DateTime @db.Date
  startTime      String?  @map("start_time") @db.VarChar(5)
  endTime        String?  @map("end_time") @db.VarChar(5)
  isClosedAllDay Boolean  @default(false) @map("is_closed_all_day")
  note           String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, date], map: "service_availability_exceptions_service_id_date_idx")
  @@map("service_availability_exceptions")
}

model Reservation {
  id                                     String            @id @default(uuid()) @db.Uuid
  serviceId                              String            @map("service_id") @db.Uuid
  customerUserId                         String            @map("customer_user_id") @db.Uuid
  serviceOwnerUserId                     String            @map("service_owner_user_id") @db.Uuid
  brandId                                String?           @map("brand_id") @db.Uuid
  requestedStartAt                       DateTime          @map("requested_start_at")
  requestedEndAt                         DateTime?         @map("requested_end_at")
  status                                 ReservationStatus
  approvalExpiresAt                      DateTime?         @map("approval_expires_at")
  customerNote                           String?           @map("customer_note")
  rejectionReason                        String?           @map("rejection_reason")
  cancellationReason                     String?           @map("cancellation_reason")
  freeCancellationEligibleAtCancellation Boolean?          @map("free_cancellation_eligible_at_cancellation")
  cancelledAt                            DateTime?         @map("cancelled_at")
  completedAt                            DateTime?         @map("completed_at")
  createdAt                              DateTime          @default(now()) @map("created_at")
  updatedAt                              DateTime          @updatedAt @map("updated_at")

  service           Service                       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  customerUser      User                          @relation("ReservationCustomer", fields: [customerUserId], references: [id], onDelete: Cascade)
  serviceOwnerUser  User                          @relation("ReservationServiceOwner", fields: [serviceOwnerUserId], references: [id], onDelete: Cascade)
  brand             Brand?                        @relation(fields: [brandId], references: [id], onDelete: SetNull)
  statusHistory     ReservationStatusHistory[]
  changeRequests    ReservationChangeRequest[]
  completionRecords ReservationCompletionRecord[]

  @@index([customerUserId, status, createdAt], map: "reservations_customer_user_id_status_created_at_idx")
  @@index([serviceOwnerUserId, status, createdAt], map: "reservations_owner_user_id_status_created_at_idx")
  @@index([serviceId, status, requestedStartAt], map: "reservations_service_id_status_start_at_idx")
  @@index([brandId], map: "reservations_brand_id_idx")
  @@map("reservations")
}

model ReservationStatusHistory {
  id            String               @id @default(uuid()) @db.Uuid
  reservationId String               @map("reservation_id") @db.Uuid
  fromStatus    ReservationStatus?   @map("from_status")
  toStatus      ReservationStatus    @map("to_status")
  reason        String?
  actorType     ReservationActorType @map("actor_type")
  actorUserId   String?              @map("actor_user_id") @db.Uuid
  createdAt     DateTime             @default(now()) @map("created_at")

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  actorUser   User?       @relation("ReservationStatusActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([reservationId, createdAt], map: "reservation_status_history_reservation_id_created_at_idx")
  @@index([actorUserId], map: "reservation_status_history_actor_user_id_idx")
  @@map("reservation_status_history")
}

model ReservationChangeRequest {
  id                String                         @id @default(uuid()) @db.Uuid
  reservationId     String                         @map("reservation_id") @db.Uuid
  requestedByUserId String                         @map("requested_by_user_id") @db.Uuid
  requestedStartAt  DateTime                       @map("requested_start_at")
  requestedEndAt    DateTime?                      @map("requested_end_at")
  reason            String
  status            ReservationChangeRequestStatus @default(PENDING)
  previousStatus    ReservationStatus              @map("previous_status")
  reviewedByUserId  String?                        @map("reviewed_by_user_id") @db.Uuid
  reviewedAt        DateTime?                      @map("reviewed_at")
  createdAt         DateTime                       @default(now()) @map("created_at")
  updatedAt         DateTime                       @updatedAt @map("updated_at")

  reservation     Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  requestedByUser User        @relation("ReservationChangeRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  reviewedByUser  User?       @relation("ReservationChangeReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([reservationId, status], map: "reservation_change_requests_reservation_id_status_idx")
  @@index([requestedByUserId, status], map: "reservation_change_requests_requested_by_status_idx")
  @@map("reservation_change_requests")
}

model ReservationCompletionRecord {
  id                     String                      @id @default(uuid()) @db.Uuid
  reservationId          String                      @map("reservation_id") @db.Uuid
  method                 ReservationCompletionMethod
  completedByUserId      String                      @map("completed_by_user_id") @db.Uuid
  customerVerifiedUserId String?                     @map("customer_verified_user_id") @db.Uuid
  qrPayloadSnapshot      String?                     @map("qr_payload_snapshot")
  createdAt              DateTime                    @default(now()) @map("created_at")

  reservation          Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  completedByUser      User        @relation("ReservationCompletionActor", fields: [completedByUserId], references: [id], onDelete: Cascade)
  customerVerifiedUser User?       @relation("ReservationCompletionVerifiedCustomer", fields: [customerVerifiedUserId], references: [id], onDelete: SetNull)

  @@index([reservationId, createdAt], map: "reservation_completion_records_reservation_id_created_at_idx")
  @@index([completedByUserId], map: "reservation_completion_records_completed_by_idx")
  @@map("reservation_completion_records")
}
