generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum AppRole {
  UCR
  USO
  ADMIN
}

enum OtpPurpose {
  REGISTER
  LOGIN
  VERIFY_PHONE
  CHANGE_PHONE
}

enum MagicLinkPurpose {
  VERIFY_EMAIL
  LOGIN_EMAIL
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  fullName        String    @map("full_name")
  email           String?   @unique
  phone           String    @unique
  emailVerifiedAt DateTime? @map("email_verified_at")
  phoneVerifiedAt DateTime? @map("phone_verified_at")
  status          UserStatus @default(ACTIVE)
  suspendedUntil  DateTime? @map("suspended_until")
  closedReason    String?   @map("closed_reason")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  roles           UserRole[]
  authSessions    AuthSession[]
  emailMagicLinks EmailMagicLink[]

  @@index([status], map: "users_status_idx")
  @@map("users")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  role      AppRole
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role], map: "user_roles_user_id_role_key")
  @@index([role], map: "user_roles_role_idx")
  @@map("user_roles")
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid @map("user_id")
  refreshTokenHash String    @map("refresh_token_hash")
  deviceInfo       String?   @map("device_info")
  ip               String?
  activeRole       AppRole   @default(UCR) @map("active_role")
  lastUsedAt       DateTime? @map("last_used_at")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt], map: "auth_sessions_user_revoked_idx")
  @@index([expiresAt], map: "auth_sessions_expires_at_idx")
  @@map("auth_sessions")
}

model OtpCode {
  id           String     @id @default(uuid()) @db.Uuid
  phone        String
  codeHash     String     @map("code_hash")
  purpose      OtpPurpose
  fullName     String?    @map("full_name")
  email        String?
  expiresAt    DateTime   @map("expires_at")
  consumedAt   DateTime?  @map("consumed_at")
  attemptCount Int        @default(0) @map("attempt_count")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([phone, purpose, consumedAt], map: "otp_codes_phone_purpose_consumed_idx")
  @@index([phone, purpose, expiresAt], map: "otp_codes_phone_purpose_expires_idx")
  @@map("otp_codes")
}

model EmailMagicLink {
  id         String           @id @default(uuid()) @db.Uuid
  userId     String?          @db.Uuid @map("user_id")
  email      String
  tokenHash  String           @map("token_hash")
  purpose    MagicLinkPurpose
  expiresAt  DateTime         @map("expires_at")
  consumedAt DateTime?        @map("consumed_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, purpose, consumedAt], map: "email_magic_links_user_purpose_consumed_idx")
  @@index([email, purpose, expiresAt], map: "email_magic_links_email_purpose_expires_idx")
  @@map("email_magic_links")
}
