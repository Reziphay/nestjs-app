NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
DATABASE_URL=postgresql://reziphay:reziphay@localhost:5432/reziphay?schema=public
REDIS_URL=redis://localhost:6379/0
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
MAGIC_LINK_TTL_MINUTES=60
AUTH_HASH_SECRET=replace-with-a-long-random-hash-secret
RESERVATION_APPROVAL_TTL_MINUTES=5
RESERVATION_REMINDER_LEAD_MINUTES=120,30
RESERVATION_QR_SECRET=replace-with-a-long-random-qr-secret
RESERVATION_QR_TTL_MINUTES=10
APP_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=.local-storage/uploads
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=reziphay-local
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=false
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
GEO_PROVIDER=none
MAPBOX_ACCESS_TOKEN=
MAPBOX_BASE_URL=https://api.mapbox.com
MAPBOX_DEFAULT_COUNTRY=
MAPBOX_DEFAULT_LANGUAGE=
SWAGGER_ENABLED=true
