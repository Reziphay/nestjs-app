NODE_ENV=development
APP_NAME=Reziphay API
PORT=3000
API_PREFIX=api/v1
SWAGGER_PATH=api/docs

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=reziphay
MYSQL_USER=reziphay
MYSQL_PASSWORD=reziphay
MYSQL_ROOT_PASSWORD=root
DATABASE_URL=mysql://reziphay:reziphay@127.0.0.1:3306/reziphay

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://127.0.0.1:6379

JWT_ACCESS_SECRET=replace-with-a-long-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-refresh-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
OTP_TTL_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_REQUEST_WINDOW_MINUTES=15
OTP_MAX_REQUESTS_PER_WINDOW=5
EMAIL_VERIFY_TTL_MINUTES=60
EMAIL_VERIFY_COOLDOWN_SECONDS=60

SEED_ADMIN_PASSWORD=Admin12345!
